{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["@cloudflare/workers-types"],
    "baseUrl": "."
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.json",
    "test/mocks/**/*.ts",
    "test/**/*.ts",
    "vitest.config.ts"
  ]
}

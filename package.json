{
  "name": "lemma-otlp-worker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "overrides": {
    "@opentelemetry/otlp-transformer": "0.214.0",
    "nanoid": "3.3.11"
  },
  "pnpm": {
    "overrides": {
      "@opentelemetry/otlp-transformer": "0.214.0",
      "nanoid": "3.3.11"
    }
  },
  "scripts": {
    "predev": "sh -c 'lsof -tiTCP:8789,9231 -sTCP:LISTEN | xargs -I {} kill {} 2>/dev/null || true'",
    "dev": "wrangler dev --config wrangler.local.toml --port 8789 --inspector-port 9231 --log-level info",
    "dev:remote": "wrangler dev --remote --port 8789 --inspector-port 9231 --log-level info",
    "deploy": "wrangler deploy",
    "type-check": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@opentelemetry/otlp-transformer": "0.214.0",
    "aws4fetch": "^1.0.20"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260410.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.12.0"
  }
}

# Shared secret for deferred-flush auth against the Lemma API (must match the
# API's WORKER_SHARED_SECRET).
#
# Not needed when running via the platform repo's `pnpm dev` — dev.sh injects
# the AWS "env" secret and runs wrangler with CLOUDFLARE_INCLUDE_PROCESS_ENV,
# so the value arrives via process env. Only needed for standalone runs
# (`pnpm dev` from this directory), which bypass dev.sh.
WORKER_SHARED_SECRET=

# The S3/payload-store config (S3_ENDPOINT, OTEL_PUT_* creds, etc.) comes from
# wrangler.local.toml [vars] for plain local dev.
